{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Spa": {
    "UseProxyInDevelopment": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=<DB_HOST>;Port=5432;Database=ballastlaneboard;Username=postgres;Password=<DB_PASSWORD>"
  },
  "OpenIdConnect": {
    "Authority": "https://your-keycloak-host/realms/ballast-lane-board",
    "Audience": "ballast-lane-board-api",
    "RoleClaimPath": "realm_access.roles"
  },
  "IdentityProvider": {
    "AdminUrl": "https://your-keycloak-host",
    "Realm": "ballast-lane-board",
    "AdminUser": "admin",
    "AdminPassword": "admin"
  }
}
