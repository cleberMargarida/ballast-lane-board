{
  "realm": "ballast-lane-board",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "ballast-lane-board",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "ballast-lane-board-spa",
      "name": "BallastLaneBoard SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5293/*",
        "http://localhost:4200/*",
        "http://localhost:8082/*",
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost:5293",
        "http://localhost:4200",
        "http://localhost:8082",
        "http://localhost"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5293/*##http://localhost:4200/*##http://localhost:8082##http://localhost:8082/*##http://localhost/*##http://localhost"
      },
      "defaultClientScopes": [
        "basic",
        "openid",
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "ballast-lane-board-api",
      "name": "BallastLaneBoard API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@ballastlaneboard.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin"
      ]
    },
    {
      "username": "testuser",
      "email": "testuser@ballastlaneboard.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ],
  "scopeMappings": [
    {
      "client": "ballast-lane-board-spa",
      "roles": [
        "user"
      ]
    }
  ]
}
